# Copy to .env and fill in.  .env is gitignored.

# LLM (used by the agent graph once wired up)
GEMINI_API_KEY=your_gemini_api_key

# GitHub App credentials (from your App's settings page)
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=a_long_random_string

# Private key: either point at the .pem file you downloaded...
GITHUB_PRIVATE_KEY_PATH=./github-app.private-key.pem
# ...or paste the PEM contents directly (use \n for newlines). Path wins if both are set.
GITHUB_PRIVATE_KEY=

# Server
PORT=8000
