# Copy to .env and fill in.  .env is gitignored.

# LLM (used by the agent graph once wired up)
GEMINI_API_KEY=your_gemini_api_key

# GitHub App credentials (from your App's settings page)
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=a_long_random_string

# Private key: either point at the .pem file you downloaded...
GITHUB_PRIVATE_KEY_PATH=./github-app.private-key.pem
# ...or paste the PEM contents directly (use \n for newlines). Path wins if both are set.
GITHUB_PRIVATE_KEY=

# Server
PORT=8000

# --- RAG (optional): repo-aware reviews via pgvector ---
# Leave DATABASE_URL unset to run diff-only exactly as before. When set, Arbiter
# indexes each repo's default branch and retrieves related code as review context.
# Local pgvector: `docker compose up -d`, then use the line below.
DATABASE_URL=postgresql://arbiter:arbiter@localhost:5432/arbiter
# Embedding model + dimension (keep in sync; text-embedding-004 = 768 dims).
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIM=768
# Retrieval / indexing tuning (optional; sensible defaults in rag/config.py).
# RAG_TOP_K=6
# RAG_MAX_FILES=600
# RAG_MAX_FILE_BYTES=100000
